<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:pages="clr-namespace:VRChatContentPublisher.App.ViewModels.Pages"
             xmlns:avalonia="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
             xmlns:localization="clr-namespace:VRChatContentPublisher.App.Localization;assembly=VRChatContentPublisher.App.Localization"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:DataType="pages:SettingsPageViewModel"
             x:Class="VRChatContentPublisher.App.Pages.SettingsPage">

    <Grid RowDefinitions="Auto,*">
        <Border>
            <Border.Background>
                <ImageBrush Source="/Assets/WelcomeHeader.png" Stretch="UniformToFill" />
            </Border.Background>
            <StackPanel Margin="18">
                <Button Content="{avalonia:MaterialIconTextExt Kind=ArrowLeft, Text=Back}"
                        Command="{Binding NavigateToHomeCommand}"
                        Padding="0" Margin="0,0,0,5" Foreground="White"
                        Theme="{StaticResource MaterialFlatButton}" HorizontalAlignment="Left" />
                <TextBlock Text="Settings" FontSize="36" FontWeight="SemiBold" Foreground="White" />
            </StackPanel>
        </Border>
        <ScrollViewer Grid.Row="1">
            <StackPanel Spacing="8" Margin="18">
                <Expander Header="{I18N {x:Static localization:LangKeys.Pages_Settings_Accounts_Title}}">
                    <ContentControl Content="{Binding AccountsSettingsViewModel}" />
                </Expander>
                <Expander Header="{I18N {x:Static localization:LangKeys.Pages_Settings_Appearance_Title}}">
                    <ContentControl Content="{Binding AppearanceSettingsViewModel}" />
                </Expander>
                <Expander Header="{I18N {x:Static localization:LangKeys.Pages_Settings_Connect_Title}}">
                    <ContentControl Content="{Binding ConnectSettingsViewModel}" />
                </Expander>
                <Expander Header="{I18N {x:Static localization:LangKeys.Pages_Settings_Notification_Title}}">
                    <ContentControl Content="{Binding NotificationSettingsViewModel}" />
                </Expander>
                <Expander Header="Sessions">
                    <ContentControl Content="{Binding SessionsSettingsViewModel}" />
                </Expander>
                <Expander Header="Http Proxy">
                    <ContentControl Content="{Binding HttpProxySettingsViewModel}" />
                </Expander>
                <Expander Header="Debug">
                    <ContentControl Content="{Binding DebugSettingsViewModel}" />
                </Expander>
                <Expander Header="{I18N {x:Static localization:LangKeys.Pages_Settings_About_Title}}">
                    <ContentControl Content="{Binding AboutSettingsViewModel}" />
                </Expander>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>