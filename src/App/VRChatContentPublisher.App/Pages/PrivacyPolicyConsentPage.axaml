<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:pages="clr-namespace:VRChatContentPublisher.App.ViewModels.Pages"
             xmlns:localization="clr-namespace:VRChatContentPublisher.App.Localization;assembly=VRChatContentPublisher.App.Localization"
             mc:Ignorable="d" d:DesignWidth="420" d:DesignHeight="600"
             x:DataType="pages:PrivacyPolicyConsentPageViewModel"
             x:Class="VRChatContentPublisher.App.Pages.PrivacyPolicyConsentPage">

    <Interaction.Behaviors>
        <AttachedToVisualTreeTrigger>
            <InvokeCommandAction Command="{Binding LoadCommand}" />
        </AttachedToVisualTreeTrigger>
    </Interaction.Behaviors>

    <ScrollViewer>
        <StackPanel Margin="24" Spacing="12" VerticalAlignment="Center">

            <!-- Title: switches between first-time consent and update notification -->
            <TextBlock Classes="Headline5" TextAlignment="Center" TextWrapping="Wrap">
                <TextBlock.Text>
                    <I18N Key="{x:Static localization:LangKeys.Pages_PrivacyConsent_Title}" />
                </TextBlock.Text>
            </TextBlock>

            <!-- Description of privacy policy -->
            <TextBlock
                Text="{I18N {x:Static localization:LangKeys.Pages_PrivacyConsent_Description}}"
                Classes="Body1" TextWrapping="Wrap" Opacity="0.8" />

            <!-- View Privacy Policy link button (opens in browser) -->
            <Button
                Content="{I18N {x:Static localization:LangKeys.Pages_PrivacyConsent_ViewPolicy}}"
                Theme="{StaticResource MaterialFlatButton}"
                HorizontalAlignment="Left">
                <Interaction.Behaviors>
                    <ClickEventTrigger>
                        <LaunchUriAction Uri="{Binding PrivacyPolicyUrl}" />
                    </ClickEventTrigger>
                </Interaction.Behaviors>
            </Button>

            <!-- Disagree warning -->
            <TextBlock
                Text="{I18N {x:Static localization:LangKeys.Pages_PrivacyConsent_DisagreeWarning}}"
                Classes="Caption" Foreground="{DynamicResource MaterialDesignErrorForeground}"
                TextWrapping="Wrap" />

            <Border Height="1" Margin="0,4,0,0"
                    Background="{DynamicResource MaterialDesignBodyLight}" />

            <!-- Telemetry CheckBoxes -->
            <CheckBox
                Content="{I18N {x:Static localization:LangKeys.Pages_Settings_Telemetry_Enable_Toggle}}"
                IsChecked="{Binding IsEnableTelemetry}" />
            <TextBlock
                Text="{I18N {x:Static localization:LangKeys.Pages_Settings_Telemetry_Enable_Toggle_Description}}"
                Classes="Caption" Opacity="0.8" TextWrapping="Wrap" Margin="24,0,0,0" />

            <CheckBox
                IsVisible="{Binding IsEnableTelemetry}"
                Content="{I18N {x:Static localization:LangKeys.Pages_Settings_Telemetry_Full_Mode_Checkbox}}"
                IsChecked="{Binding IsFullMode}" />
            <TextBlock
                IsVisible="{Binding IsEnableTelemetry}"
                Text="{I18N {x:Static localization:LangKeys.Pages_Settings_Telemetry_Full_Mode_Checkbox_Description}}"
                Classes="Caption" Opacity="0.8" TextWrapping="Wrap" Margin="24,0,0,0" />

            <Border Height="1" Margin="0,4,0,0"
                    Background="{DynamicResource MaterialDesignBodyLight}" />

            <!-- Action buttons -->
            <StackPanel Spacing="8" Margin="0,8,0,0">
                <Button
                    Classes="accent"
                    Content="{I18N {x:Static localization:LangKeys.Pages_PrivacyConsent_AgreeAndContinue}}"
                    Command="{Binding AgreeAndContinueCommand}" />

                <Button
                    Theme="{StaticResource MaterialOutlineButton}"
                    Content="{I18N {x:Static localization:LangKeys.Pages_PrivacyConsent_ExitApp}}"
                    Command="{Binding DisagreeAndExitCommand}" />
            </StackPanel>

        </StackPanel>
    </ScrollViewer>
</UserControl>
