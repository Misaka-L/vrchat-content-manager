<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:gettingStarted="clr-namespace:VRChatContentPublisher.App.ViewModels.Pages.GettingStarted"
             xmlns:assists="clr-namespace:Material.Styles.Assists;assembly=Material.Styles"
             xmlns:avalonia="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
             xmlns:localization="clr-namespace:VRChatContentPublisher.App.Localization;assembly=VRChatContentPublisher.App.Localization"
             mc:Ignorable="d" d:DesignWidth="430" d:DesignHeight="680"
             x:DataType="gettingStarted:GuideSetupUnityPageViewModel"
             x:Class="VRChatContentPublisher.App.Pages.GettingStarted.GuideSetupUnityPage">

    <Interaction.Behaviors>
        <AttachedToVisualTreeTrigger>
            <InvokeCommandAction Command="{Binding LoadCommand}" />
        </AttachedToVisualTreeTrigger>
        <DetachedFromVisualTreeTrigger>
            <InvokeCommandAction Command="{Binding UnloadCommand}" />
        </DetachedFromVisualTreeTrigger>
    </Interaction.Behaviors>

    <Grid RowDefinitions="Auto,*,Auto">
        <Border MinHeight="90">
            <Border.Background>
                <ImageBrush Source="/Assets/WelcomeHeader.png" Stretch="UniformToFill" />
            </Border.Background>
            <StackPanel Margin="18">
                <TextBlock
                    Text="{I18N {x:Static localization:LangKeys.Pages_Guide_Setup_Unity_Headline1_Light}}"
                    FontSize="16" Foreground="White" Opacity="0.7" />
                <TextBlock Text="{I18N {x:Static localization:LangKeys.Pages_Guide_Setup_Unity_Headline2_Bold}}"
                           FontSize="36" FontWeight="SemiBold" Foreground="White" />
            </StackPanel>
        </Border>

        <StackPanel Grid.Row="1" Margin="18" Spacing="12">
            <StackPanel Spacing="8">
                <Border BorderBrush="{DynamicResource MaterialDesignBodyLight}"
                        BorderThickness="2,0,0,0"
                        Padding="8,0,0,0">
                    <StackPanel>
                        <TextBlock Classes="Caption"
                                   Text="{I18N {x:Static localization:LangKeys.Pages_Guide_Shared_Steps_Step_1_Title}}"
                                   Opacity="0.8" />
                        <TextBlock Classes="Headline6"
                                   Text="{I18N {x:Static localization:LangKeys.Pages_Guide_Setup_Unity_Step_1_Add_VPM_Repository_Title}}"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </Border>
                <TextBox UseFloatingPlaceholder="True" Classes="outline" Theme="{StaticResource OutlineTextBox}"
                         assists:TextFieldAssist.Label="{I18N {x:Static localization:LangKeys.Pages_Guide_Setup_Unity_Step_1_VPM_Repository_URL_Field_Hint}}"
                         IsReadOnly="True" Text="{Binding VpmRepositoryUrl}" />

                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                    <Button>
                        <Interaction.Behaviors>
                            <ButtonClickEventTriggerBehavior>
                                <LaunchUriAction Uri="{Binding PackageManagerUrl}" />
                            </ButtonClickEventTriggerBehavior>
                        </Interaction.Behaviors>
                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <avalonia:MaterialIcon Kind="PackageVariantClosedPlus" />
                            <TextBlock
                                Text="{I18N {x:Static localization:LangKeys.Pages_Guide_Setup_Unity_Step_1_Add_To_Package_Manager_Button_Text}}" />
                        </StackPanel>
                    </Button>
                    <Button Grid.Column="1" Theme="{StaticResource MaterialOutlineButton}" Classes="light">
                        <Interaction.Behaviors>
                            <ButtonClickEventTriggerBehavior>
                                <SetClipboardTextAction Text="{Binding VpmRepositoryUrl}" />
                            </ButtonClickEventTriggerBehavior>
                        </Interaction.Behaviors>
                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <avalonia:MaterialIcon Kind="ContentCopy" />
                            <TextBlock
                                Text="{I18N {x:Static localization:LangKeys.Pages_Guide_Setup_Unity_Step_1_Copy_Repository_URL_Button_Text}}" />
                        </StackPanel>
                    </Button>
                </Grid>
            </StackPanel>

            <StackPanel Spacing="4">
                <Border BorderBrush="{DynamicResource MaterialDesignBodyLight}"
                        BorderThickness="2,0,0,0"
                        Padding="8,0,0,0"
                        Margin="0,0,0,4">
                    <StackPanel>
                        <TextBlock Classes="Caption"
                                   Text="{I18N {x:Static localization:LangKeys.Pages_Guide_Shared_Steps_Step_2_Title}}"
                                   Opacity="0.8" />
                        <TextBlock Classes="Headline6"
                                   Text="{I18N {x:Static localization:LangKeys.Pages_Guide_Setup_Unity_Step_2_Install_Connect_Package_Title}}"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <StackPanel Margin="2 0">
                    <TextBlock Classes="Caption"
                               Text="{I18N {x:Static localization:LangKeys.Pages_Guide_Setup_Unity_Step_2_For_Worlds_Project_Caption}}"
                               Opacity="0.6" />
                    <SelectableTextBlock TextWrapping="Wrap" Text="VRChat Content Publisher Connect - Worlds" />
                </StackPanel>
                <StackPanel Margin="2 0">
                    <TextBlock Classes="Caption"
                               Text="{I18N {x:Static localization:LangKeys.Pages_Guide_Setup_Unity_Step_2_For_Avatars_Project_Caption}}"
                               Opacity="0.6" />
                    <SelectableTextBlock TextWrapping="Wrap" Text="VRChat Content Publisher Connect - Avatars" />
                </StackPanel>
                <StackPanel Margin="2 0">
                    <TextBlock Classes="Caption"
                               Text="{I18N {x:Static localization:LangKeys.Pages_Guide_Setup_Unity_Step_2_For_Project_With_CAU_Caption}}"
                               Opacity="0.6" />
                    <SelectableTextBlock TextWrapping="Wrap"
                                         Text="VRChat Content Publisher Connect - Avatars - Continuous Avatar Uploader Extension" />
                </StackPanel>
            </StackPanel>
        </StackPanel>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right"
                    Margin="18 14" Spacing="8">
            <Button Theme="{StaticResource MaterialOutlineButton}"
                    Foreground="{DynamicResource MaterialDesignBody}"
                    BorderBrush="{DynamicResource MaterialDesignBodyLight}"
                    Content="{I18N {x:Static localization:LangKeys.Pages_Guide_Setup_Unity_Skip_Button_Text}}"
                    Command="{Binding SkipCommand}" />
            <Button Content="{I18N {x:Static localization:LangKeys.Pages_Guide_Setup_Unity_Next_Button_Text}}"
                    Command="{Binding NextCommand}" />
        </StackPanel>
    </Grid>
</UserControl>