<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:homeTab="clr-namespace:VRChatContentPublisher.App.ViewModels.Pages.HomeTab"
             xmlns:avalonia="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
             xmlns:publishTasks="clr-namespace:VRChatContentPublisher.App.ViewModels.Data.PublishTasks"
             xmlns:controls="clr-namespace:VRChatContentPublisher.App.Controls"
             xmlns:controls1="clr-namespace:Material.Styles.Controls;assembly=Material.Styles"
             xmlns:localization="clr-namespace:VRChatContentPublisher.App.Localization;assembly=VRChatContentPublisher.App.Localization"
             mc:Ignorable="d" d:DesignWidth="400" d:DesignHeight="450"
             x:DataType="homeTab:HomeTasksPageViewModel"
             x:Class="VRChatContentPublisher.App.Pages.HomeTab.HomeTasksPage">

    <Interaction.Behaviors>
        <AttachedToVisualTreeTrigger>
            <InvokeCommandAction Command="{Binding LoadCommand}" />
        </AttachedToVisualTreeTrigger>
        <DetachedFromVisualTreeTrigger>
            <InvokeCommandAction Command="{Binding UnloadCommand}" />
        </DetachedFromVisualTreeTrigger>
    </Interaction.Behaviors>

    <Grid RowDefinitions="Auto,*">
        <Border Grid.Row="0"
                IsVisible="{Binding IsPublicIpWarningVisible}"
                Background="#FF6D00">
            <Grid ColumnDefinitions="Auto,*,Auto" Margin="8">
                <avalonia:MaterialIcon Kind="AlertCircle" Foreground="White" VerticalAlignment="Top"
                                       Margin="0,0,8,0" />
                <TextBlock Grid.Column="1"
                           Text="{I18N {x:Static localization:LangKeys.Pages_Tasks_Alert_Public_IP_Changed_Message}}"
                           Foreground="White"
                           VerticalAlignment="Top"
                           TextWrapping="Wrap" />
                <StackPanel Grid.Column="2">
                    <Button
                        Theme="{StaticResource MaterialFlatButton}"
                        Foreground="White"
                        Content="{I18N {x:Static localization:LangKeys.Pages_Tasks_Alert_Public_IP_Changed_Show_IP_Button_Text}}"
                        VerticalAlignment="Center">
                        <Button.Flyout>
                            <Flyout>
                                <StackPanel>
                                    <SelectableTextBlock>
                                        <Bold>
                                            <Run
                                                Text="{I18N {x:Static localization:LangKeys.Pages_Tasks_Alert_Public_IP_Changed_Current_Public_IP_Text}}" />
                                        </Bold>
                                        <Run Text="{Binding LastPublicIp, FallbackValue=N/A}" />
                                    </SelectableTextBlock>
                                    <SelectableTextBlock>
                                        <Bold>
                                            <Run
                                                Text="{I18N {x:Static localization:LangKeys.Pages_Tasks_Alert_Public_IP_Changed_Last_Public_IP_Text}}" />
                                        </Bold>
                                        <Run Text="{Binding LastPreviousPublicIp, FallbackValue=N/A}" />
                                    </SelectableTextBlock>
                                </StackPanel>
                            </Flyout>
                        </Button.Flyout>
                    </Button>
                    <Button
                        Theme="{StaticResource MaterialFlatButton}"
                        Foreground="White"
                        Command="{Binding DismissPublicIpWarningCommand}"
                        Content="{I18N {x:Static localization:LangKeys.Pages_Tasks_Alert_Public_IP_Changed_Dismiss_Button_Text}}"
                        VerticalAlignment="Center" />
                </StackPanel>
            </Grid>
        </Border>

        <Panel Grid.Row="1">
            <Grid RowDefinitions="Auto,*"
                  IsVisible="{Binding TaskManagers.Count}">
                <controls1:ColorZone>
                    <Grid ColumnDefinitions="*,Auto">
                        <ScrollViewer HorizontalScrollBarVisibility="Auto">
                            <Interaction.Behaviors>
                                <HorizontalScrollViewerBehavior RequireShiftKey="False" ScrollChangeSize="Line" />
                            </Interaction.Behaviors>
                            <ListBox ItemsSource="{Binding TaskManagers}"
                                     SelectedItem="{Binding SelectedTaskManagerContainerViewModel}"
                                     SelectionMode="Single">
                                <ListBox.Styles>
                                    <Style Selector="ListBoxItem">
                                        <Setter Property="BorderThickness" Value="0,0,0,1" />
                                    </Style>
                                    <Style Selector="ListBoxItem:selected">
                                        <Setter Property="BorderBrush"
                                                Value="{DynamicResource MaterialDesignBodyLight}" />
                                    </Style>
                                </ListBox.Styles>
                                <ListBox.ItemTemplate>
                                    <DataTemplate x:DataType="publishTasks:PublishTaskManagerContainerViewModel">
                                        <StackPanel Orientation="Horizontal" Spacing="4">
                                            <Border
                                                IsVisible="{Binding AvatarUri, Converter={x:Static ObjectConverters.IsNotNull}}"
                                                CornerRadius="100" Height="18" Width="18" ClipToBounds="True">
                                                <Image controls:AsyncImageLoader.Source="{Binding AvatarUri}"
                                                       Stretch="UniformToFill" />
                                            </Border>
                                            <TextBlock Text="{Binding DisplayName}" VerticalAlignment="Center" />
                                        </StackPanel>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                                <ListBox.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal" />
                                    </ItemsPanelTemplate>
                                </ListBox.ItemsPanel>
                            </ListBox>
                        </ScrollViewer>
                        <Button Grid.Column="1"
                                Name="AddAccountButton"
                                Theme="{StaticResource MaterialFlatButton}"
                                Command="{Binding LoginCommand}"
                                Content="{avalonia:MaterialIconExt Kind=Add, Size=24}"
                                Width="{Binding #AddAccountButton.Bounds.Height}"
                                ToolTip.Tip="{I18N {x:Static localization:LangKeys.Pages_Tasks_Tabs_Add_New_Account_Button_Tooltip}}" />
                    </Grid>
                </controls1:ColorZone>
                <TransitioningContentControl Grid.Row="1" Content="{Binding SelectedTaskManagerContainerViewModel}" />
            </Grid>
            <StackPanel IsVisible="{Binding !TaskManagers.Count}"
                        Spacing="12" Margin="0,24,0,0">
                <avalonia:MaterialIcon Kind="QuestionBoxMultiple" Height="64" Width="64" />
                <TextBlock Text="{I18N {x:Static localization:LangKeys.Pages_Tasks_No_VRChat_Account_Exist_Title}}"
                           HorizontalAlignment="Center"
                           FontSize="18" />
                <Button
                    Content="{I18N {x:Static localization:LangKeys.Pages_Tasks_No_VRChat_Account_Exist_Login_Button_Text}}"
                    HorizontalAlignment="Center" MinWidth="200"
                    Command="{Binding LoginCommand}" />
            </StackPanel>
        </Panel>
    </Grid>
</UserControl>