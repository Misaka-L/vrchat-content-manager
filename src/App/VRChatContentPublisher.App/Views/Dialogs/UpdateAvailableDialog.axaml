<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:dialogs="clr-namespace:VRChatContentPublisher.App.ViewModels.Dialogs"
             xmlns:localization="clr-namespace:VRChatContentPublisher.App.Localization;assembly=VRChatContentPublisher.App.Localization"
             xmlns:avalonia="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
             mc:Ignorable="d" d:DesignWidth="350" d:DesignHeight="420"
             x:DataType="dialogs:UpdateAvailableDialogViewModel"
             x:Class="VRChatContentPublisher.App.Views.Dialogs.UpdateAvailableDialog">

    <Interaction.Behaviors>
        <AttachedToVisualTreeTrigger>
            <InvokeCommandAction Command="{Binding LoadCommand}" />
        </AttachedToVisualTreeTrigger>
        <DetachedFromVisualTreeTrigger>
            <InvokeCommandAction Command="{Binding UnloadCommand}" />
        </DetachedFromVisualTreeTrigger>
    </Interaction.Behaviors>

    <Grid Width="340" Height="360" RowDefinitions="Auto,*,Auto" RowSpacing="8" Margin="4">
        <Border BorderBrush="{DynamicResource MaterialDesignBodyLight}"
                BorderThickness="0,0,0,1" Padding="0,0,0,4">
            <Grid ColumnDefinitions="*,Auto">
                <StackPanel>
                    <TextBlock Text="{I18N {x:Static localization:LangKeys.Dialog_Update_Available_Headline}}"
                               Classes="Subtitle2" />
                    <TextBlock Text="{Binding Version, StringFormat='v{0}'}"
                               Classes="Headline5" />
                    <TextBlock Classes="Caption" Opacity="0.8">
                        <TextBlock.Text>
                            <I18N
                                Key="{x:Static localization:LangKeys.Dialog_Update_Available_Subtitle_Release_Date_Template}">
                                <Binding Path="ReleaseDate" StringFormat="f" />
                            </I18N>
                        </TextBlock.Text>
                    </TextBlock>
                </StackPanel>

                <Button Grid.Column="1" VerticalAlignment="Top" HorizontalAlignment="Right"
                        Theme="{StaticResource MaterialOutlineButton}" Classes="light">
                    <Interaction.Behaviors>
                        <ClickEventTrigger>
                            <LaunchUriAction Uri="{Binding BrowserUrl}" />
                        </ClickEventTrigger>
                    </Interaction.Behaviors>
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <avalonia:MaterialIcon Kind="Earth" />
                        <TextBlock
                            Text="{I18N {x:Static localization:LangKeys.Dialog_Update_Available_View_On_Browser_Button_Text}}" />
                    </StackPanel>
                </Button>
            </Grid>
        </Border>
        <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Auto">
            <SelectableTextBlock Text="{Binding Notes}" />
        </ScrollViewer>
        <StackPanel Grid.Row="2" Spacing="4">
            <TextBlock
                Text="{I18N {x:Static localization:LangKeys.Dialog_Update_Available_Uncompleted_Tasks_Exist_Warning}}"
                TextWrapping="Wrap" TextAlignment="Center"
                IsVisible="{Binding !IsSafeToShutdown}" />

            <!-- State: Idle — update available, not yet started -->
            <StackPanel IsVisible="{Binding IsIdle}" Spacing="4">
                <Button
                    Content="{I18N {x:Static localization:LangKeys.Dialog_Update_Available_Download_Update_Button_Text}}"
                    Command="{Binding StartDownloadOrInstallUpdateCommand}"
                    IsEnabled="{Binding IsUpdateInstallationSupported}" />
                <TextBlock
                    Text="{I18N {x:Static localization:LangKeys.Common_Views_Update_Progress_View_Install_Update_Disabled_Due_To_Platform_Not_Supported}}"
                    TextWrapping="Wrap" TextAlignment="Center"
                    IsVisible="{Binding !IsUpdateInstallationSupported}" />
                <Grid ColumnDefinitions="*,*" ColumnSpacing="4">
                    <Button
                        Content="{I18N {x:Static localization:LangKeys.Dialog_Update_Available_Skip_Version_Button_Text}}"
                        Theme="{StaticResource MaterialFlatButton}"
                        Command="{Binding MarkVersionAsSkippedCommand}" />
                    <Button Grid.Column="1"
                            Content="{I18N {x:Static localization:LangKeys.Dialog_Update_Available_Cancel_Button_Text}}"
                            Theme="{StaticResource MaterialFlatButton}"
                            Command="{Binding RequestCloseCommand}" />
                </Grid>
            </StackPanel>

            <!-- State: Downloading -->
            <StackPanel IsVisible="{Binding IsDownloading}" Spacing="4">
                <ContentControl Content="{Binding UpdateDownloadProgressViewModel}" />
                <Button
                    Content="{I18N {x:Static localization:LangKeys.Dialog_Update_Available_Cancel_Button_Text}}"
                    Theme="{StaticResource MaterialFlatButton}"
                    Command="{Binding RequestCloseCommand}" />
            </StackPanel>

            <!-- State: WaitingForInstall — downloaded, ready to install -->
            <StackPanel IsVisible="{Binding IsWaitingForInstall}" Spacing="4">
                <Button
                    Content="{I18N {x:Static localization:LangKeys.Dialog_Update_Available_Install_Update_Button_Text}}"
                    Command="{Binding StartDownloadOrInstallUpdateCommand}"
                    IsEnabled="{Binding IsUpdateInstallationSupported}" />
                <Grid ColumnDefinitions="*,*" ColumnSpacing="4">
                    <Button
                        Content="{I18N {x:Static localization:LangKeys.Dialog_Cancel_Update_Confirmation_Confirm_Cancel}}"
                        Theme="{StaticResource MaterialFlatButton}"
                        Command="{Binding CancelUpdateCommand}" />
                    <Button Grid.Column="1"
                            Content="{I18N {x:Static localization:LangKeys.Dialog_Update_Available_Cancel_Button_Text}}"
                            Theme="{StaticResource MaterialFlatButton}"
                            Command="{Binding RequestCloseCommand}" />
                </Grid>
            </StackPanel>
        </StackPanel>
    </Grid>
</UserControl>