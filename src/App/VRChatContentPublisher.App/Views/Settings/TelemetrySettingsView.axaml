<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:settings="clr-namespace:VRChatContentPublisher.App.ViewModels.Settings"
             xmlns:localization="clr-namespace:VRChatContentPublisher.App.Localization;assembly=VRChatContentPublisher.App.Localization"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:DataType="settings:TelemetrySettingsViewModel"
             x:Class="VRChatContentPublisher.App.Views.Settings.TelemetrySettingsView">

    <StackPanel Margin="8" Spacing="4">
        <StackPanel Spacing="4">
            <ToggleSwitch
                IsEnabled="{Binding IsTelemetryEnabled}"
                IsChecked="{Binding IsFullMode}">
                <TextBlock
                    Text="{I18N {x:Static localization:LangKeys.Pages_Settings_Telemetry_Full_Mode_Checkbox_Description}}"
                    TextWrapping="Wrap" />
            </ToggleSwitch>
            <ToggleSwitch
                IsChecked="{Binding IsTelemetryEnabled}">
                <TextBlock
                    Text="{I18N {x:Static localization:LangKeys.Pages_Settings_Telemetry_Enable_Toggle_Description}}"
                    TextWrapping="Wrap" />
            </ToggleSwitch>
        </StackPanel>

        <Border Height="1" Margin="0,4,0,0" Background="{DynamicResource MaterialDesignBodyLight}" />

        <HyperlinkButton
            Content="{I18N {x:Static localization:LangKeys.Pages_Settings_Telemetry_Privacy_Policy_Link}}"
            NavigateUri="{Binding PrivacyPolicyUrl}" />
        <HyperlinkButton
            FontWeight="Bold"
            NavigateUri="https://hello.vrchat.com/privacy">
            <TextBlock TextWrapping="Wrap"
                       Text="{I18N {x:Static localization:LangKeys.Pages_PrivacyConsent_VRChat_ViewPolicy}}" />
        </HyperlinkButton>
    </StackPanel>
</UserControl>