<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:settings="clr-namespace:VRChatContentPublisher.App.ViewModels.Settings"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:DataType="settings:NotificationSettingsViewModel"
             x:Class="VRChatContentPublisher.App.Views.Settings.NotificationSettingsView">

    <StackPanel Margin="8" Spacing="8">
        <TextBlock Text="Send notifications when" FontWeight="SemiBold"/>
        <ToggleSwitch Content="Session restore failed on startup"
                      IsChecked="{Binding SendNotificationOnStartupSessionRestoreFailed}" />
        <ToggleSwitch Content="Publish task failed"
                      IsChecked="{Binding SendNotificationOnTaskFailed}" />
        <ToggleSwitch Content="Public IP changed"
                      IsChecked="{Binding SendNotificationOnPublicIpChanged}" />
    </StackPanel>
</UserControl>

