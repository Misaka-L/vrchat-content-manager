<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:settings="clr-namespace:VRChatContentPublisher.App.ViewModels.Settings"
             xmlns:localization="clr-namespace:VRChatContentPublisher.App.Localization;assembly=VRChatContentPublisher.App.Localization"
             xmlns:avalonia="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:DataType="settings:NotificationSettingsViewModel"
             x:Class="VRChatContentPublisher.App.Views.Settings.NotificationSettingsView">

    <StackPanel Margin="8" Spacing="8">
        <Border IsVisible="{Binding IsNotificationInitializeFailed}"
                Background="#FF6D00"
                CornerRadius="8">
            <StackPanel Margin="8" Spacing="4">
                <StackPanel Orientation="Horizontal" Spacing="4">
                    <avalonia:MaterialIcon Kind="AlertCircle" Height="18" Width="18"
                                           Foreground="White" />
                    <TextBlock
                        Text="{I18N {x:Static localization:LangKeys.In_App_Notifications_Desktop_Notification_Unavailable_Title}}"
                        FontWeight="Bold" FontSize="18"
                        Foreground="White" />
                </StackPanel>
                <TextBlock Foreground="White" TextWrapping="Wrap">
                    <TextBlock.Text>
                        <I18N
                            Key="{x:Static localization:LangKeys.In_App_Notifications_Desktop_Notification_Unavailable_Body_Template}">
                            <Binding Path="LastNotificationInitializationErrorMessage" />
                        </I18N>
                    </TextBlock.Text>
                </TextBlock>
            </StackPanel>
        </Border>
        <Border IsVisible="{Binding !IsDesktopNotificationSupported}"
                Background="#FF6D00"
                CornerRadius="8">
            <StackPanel Margin="8" Spacing="4">
                <StackPanel Orientation="Horizontal" Spacing="4">
                    <avalonia:MaterialIcon Kind="AlertCircle" Height="18" Width="18"
                                           Foreground="White" />
                    <TextBlock
                        Text="{I18N {x:Static localization:LangKeys.Pages_Settings_Notification_Alert_Platform_Not_Supported_Title}}"
                        FontWeight="Bold" FontSize="18"
                        Foreground="White" />
                </StackPanel>
            </StackPanel>
        </Border>

        <ToggleSwitch
            Content="{I18N {x:Static localization:LangKeys.Pages_Settings_Notification_Enable_Notifications_Toggle_Label}}"
            IsChecked="{Binding EnabledNotifications}" />
        <Button Content="{I18N {x:Static localization:LangKeys.Pages_Settings_Notification_Send_Test_Notification}}"
                Command="{Binding SendTestNotificationCommand}"
                IsEnabled="{Binding EnabledNotifications}" />
        <TextBlock
            Text="{I18N {x:Static localization:LangKeys.Pages_Settings_Notification_Send_Notifications_When_Title}}"
            FontWeight="SemiBold" />
        <ToggleSwitch
            Content="{I18N {x:Static localization:LangKeys.Pages_Settings_Notification_Send_Notifications_When_Account_Session_Expired_On_Startup}}"
            IsEnabled="{Binding EnabledNotifications}"
            IsChecked="{Binding SendNotificationOnStartupSessionRestoreFailed}" />
        <ToggleSwitch
            Content="{I18N {x:Static localization:LangKeys.Pages_Settings_Notification_Send_Notifications_When_Publish_Task_Failed}}"
            IsEnabled="{Binding EnabledNotifications}"
            IsChecked="{Binding SendNotificationOnTaskFailed}" />
        <ToggleSwitch
            Content="{I18N {x:Static localization:LangKeys.Pages_Settings_Notification_Send_Notifications_When_Public_IP_Changed}}"
            IsEnabled="{Binding EnabledNotifications}"
            IsChecked="{Binding SendNotificationOnPublicIpChanged}" />
        <ToggleSwitch
            Content="{I18N {x:Static localization:LangKeys.Pages_Settings_Notification_Send_Notifications_When_New_Pairing_Request}}"
            IsEnabled="{Binding EnabledNotifications}"
            IsChecked="{Binding SendNotificationOnNewPairingRequest}" />
    </StackPanel>
</UserControl>