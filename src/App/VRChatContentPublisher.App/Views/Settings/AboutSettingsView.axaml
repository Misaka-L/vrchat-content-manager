<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:settings="clr-namespace:VRChatContentPublisher.App.ViewModels.Settings"
             xmlns:avalonia="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
             xmlns:localization="clr-namespace:VRChatContentPublisher.App.Localization;assembly=VRChatContentPublisher.App.Localization"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="600"
             x:DataType="settings:AboutSettingsViewModel"
             x:Class="VRChatContentPublisher.App.Views.Settings.AboutSettingsView">

    <UserControl.Styles>
        <Style Selector="HyperlinkButton > AccessText">
            <Setter Property="Foreground" Value="{DynamicResource MaterialDesignBody}" />
            <Setter Property="TextDecorations"></Setter>
        </Style>
        <Style Selector="Border.Card">
            <Setter Property="Background" Value="{DynamicResource MaterialDesignPaper}" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Padding" Value="12" />
        </Style>
        <Style Selector="Border.Divider">
            <Setter Property="Height" Value="1" />
            <Setter Property="Background" Value="{DynamicResource MaterialDesignBodyLight}" />
            <Setter Property="Opacity" Value="0.3" />
            <Setter Property="Margin" Value="0,2" />
        </Style>
        <Style Selector="TextBlock.LabelText">
            <Setter Property="FontSize" Value="11" />
        </Style>
    </UserControl.Styles>

    <ScrollViewer>
        <StackPanel Margin="16,12" Spacing="12">

            <!-- ========== Header: App Icon + Name + Version ========== -->
            <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
                <Border Background="Black" CornerRadius="14" Padding="10"
                        VerticalAlignment="Top">
                    <PathIcon Height="40" Width="40" Data="{StaticResource AppIconGeometry}" Foreground="White" />
                </Border>

                <StackPanel Spacing="4" VerticalAlignment="Center">
                    <TextBlock Text="VRChat Content Publisher"
                               FontSize="18" FontWeight="Bold" />
                    <Border BorderBrush="{DynamicResource MaterialDesignBodyLight}"
                            BorderThickness="1"
                            CornerRadius="8" Padding="6,2"
                            Opacity="0.5" HorizontalAlignment="Left">
                        <TextBlock Text="{Binding AppVersion}"
                                   FontSize="12" FontWeight="Medium" />
                    </Border>
                </StackPanel>
            </StackPanel>

            <!-- ========== Links & Build Info ========== -->
            <Border Classes="Card">
                <StackPanel Spacing="8">
                    <!-- Community Links -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="12">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <avalonia:MaterialIcon Kind="Github" Height="16" Width="16"
                                                   Opacity="0.75" />
                            <HyperlinkButton Content="GitHub"
                                             NavigateUri="https://github.com/project-vrcz/content-publisher"
                                             FontSize="13" />
                        </StackPanel>
                        <TextBlock Text="·" VerticalAlignment="Center" Opacity="0.3" />
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <avalonia:MaterialIcon Kind="Forum" Height="16" Width="16"
                                                   Opacity="0.75" />
                            <HyperlinkButton Content="QQ (1045956775)"
                                             NavigateUri="https://qm.qq.com/q/sfc4eaKoa4"
                                             FontSize="13" />
                        </StackPanel>
                    </StackPanel>

                    <Border Classes="Divider" />

                    <!-- Build Info -->
                    <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto" ColumnSpacing="10" RowSpacing="5">
                        <avalonia:MaterialIcon Grid.Row="0" Grid.Column="0"
                                               Kind="SourceCommit" Height="14" Width="14"
                                               VerticalAlignment="Center" Opacity="0.7" />
                        <StackPanel Grid.Row="0" Grid.Column="1" Spacing="1">
                            <TextBlock Text="{I18N {x:Static localization:LangKeys.Pages_Settings_About_Build_Commit}}"
                                       Classes="LabelText" />
                            <SelectableTextBlock Text="{Binding AppCommitHash}"
                                                 FontFamily="Consolas,monospace" FontSize="12" />
                        </StackPanel>

                        <avalonia:MaterialIcon Grid.Row="1" Grid.Column="0"
                                               Kind="CalendarClock" Height="14" Width="14"
                                               VerticalAlignment="Center" Opacity="0.7" />
                        <StackPanel Grid.Row="1" Grid.Column="1" Spacing="1">
                            <TextBlock Text="{I18N {x:Static localization:LangKeys.Pages_Settings_About_Build_At}}"
                                       Classes="LabelText" />
                            <SelectableTextBlock Text="{Binding AppBuildDate}" FontSize="12" />
                        </StackPanel>
                    </Grid>

                    <Border Classes="Divider" />

                    <!-- License -->
                    <HyperlinkButton Content="{I18N {x:Static localization:LangKeys.Pages_Settings_Copyright}}"
                                     HorizontalAlignment="Center"
                                     Command="{Binding NavigateToLicenseCommand}"
                                     FontSize="13" />
                </StackPanel>
            </Border>

            <!-- ========== Acknowledgements & Credits ========== -->
            <Border Classes="Card">
                <StackPanel Spacing="8">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="6">
                        <avalonia:MaterialIcon Kind="Heart" Height="18" Width="18"
                                               Foreground="IndianRed" />
                        <TextBlock
                            Text="{I18N {x:Static localization:LangKeys.Pages_Settings_About_Acknowledgement_Title}}"
                            VerticalAlignment="Center"
                            FontSize="15" FontWeight="SemiBold" />
                    </StackPanel>

                    <!-- AssetsTools.NET -->
                    <StackPanel Spacing="2">
                        <TextBlock
                            Text="{I18N {x:Static localization:LangKeys.Pages_Settings_About_AssetsTools_Unity_AssetBundle_Processing_Powered_By}}"
                            TextAlignment="Center" FontSize="12" />
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="6">
                            <HyperlinkButton Content="AssetsTools.NET"
                                             NavigateUri="https://github.com/nesrak1/AssetsTools.NET"
                                             FontSize="12" />
                            <TextBlock Text="·" VerticalAlignment="Center" Opacity="0.4" />
                            <TextBlock Text="MIT © nesrak1" VerticalAlignment="Center"
                                       FontSize="12" />
                        </StackPanel>
                        <HyperlinkButton
                            Content="{I18N {x:Static localization:LangKeys.Pages_Settings_About_AssetsTools_Modify_To_Meet_VCP_Requirements}}"
                            NavigateUri="https://github.com/project-vrcz/AssetsTools.NET"
                            HorizontalAlignment="Center"
                            FontSize="12" />
                    </StackPanel>

                    <Border Classes="Divider" />

                    <!-- VRChat API -->
                    <StackPanel Spacing="2">
                        <TextBlock
                            Text="{I18N {x:Static localization:LangKeys.Pages_Settings_About_VRChat_API_Documentation_Provided_By}}"
                            TextAlignment="Center" FontSize="12" />
                        <HyperlinkButton Content="VRChat.community"
                                         NavigateUri="https://vrchat.community/"
                                         HorizontalAlignment="Center" FontSize="12" />
                    </StackPanel>

                    <Border Classes="Divider" />

                    <!-- Third Party Notices -->
                    <HyperlinkButton HorizontalAlignment="Center" FontSize="12"
                                     Margin="0" Padding="0">
                        <HyperlinkButton.Content>
                            <StackPanel Orientation="Horizontal" Spacing="4">
                                <avalonia:MaterialIcon Kind="FileDocumentOutline"
                                                       Height="14" Width="14"
                                                       Opacity="0.7" />
                                <TextBlock
                                    Text="{I18N {x:Static localization:LangKeys.Pages_Settings_About_Thanks_To_Those_Open_Soure_Software}}" />
                            </StackPanel>
                        </HyperlinkButton.Content>
                        <Interaction.Behaviors>
                            <ButtonClickEventTriggerBehavior>
                                <LaunchUriOrFileAction Path="{Binding ThirdPartNoticePath}" />
                            </ButtonClickEventTriggerBehavior>
                        </Interaction.Behaviors>
                    </HyperlinkButton>
                </StackPanel>
            </Border>

            <!-- ========== Special Thanks ========== -->
            <Border Classes="Card">
                <StackPanel Spacing="8">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="6">
                        <avalonia:MaterialIcon Kind="Star" Height="14" Width="14"
                                               Foreground="Goldenrod" />
                        <TextBlock
                            Text="{I18N {x:Static localization:LangKeys.Pages_Settings_About_Special_Thanks_To_Our_Early_Adopters}}"
                            FontSize="13" FontWeight="Medium" />
                    </StackPanel>

                    <ItemsControl ItemsSource="{Binding EarlySupporters}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel HorizontalAlignment="Center" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.DataTemplates>
                            <DataTemplate x:DataType="settings:AboutSettingsViewModel+EarlySupporter">
                                <Button Theme="{StaticResource MaterialFlatButton}"
                                        Content="{Binding Name}"
                                        FontSize="12" Padding="10,4" Margin="3">
                                    <Interaction.Behaviors>
                                        <ButtonClickEventTriggerBehavior>
                                            <LaunchUriOrFileAction Path="{Binding Url}" />
                                        </ButtonClickEventTriggerBehavior>
                                    </Interaction.Behaviors>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.DataTemplates>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <!-- ========== Support ========== -->
            <Border Classes="Card">
                <StackPanel Spacing="8">
                    <TextBlock Text="{I18N {x:Static localization:LangKeys.Pages_Settings_About_Consider_Support_By}}"
                               HorizontalAlignment="Center"
                               FontSize="13" FontWeight="Medium" />

                    <ItemsControl ItemsSource="{Binding SupportActions}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="8" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.DataTemplates>
                            <DataTemplate x:DataType="settings:AboutSettingsViewModel+SupportAction">
                                <Button Theme="{StaticResource MaterialFlatButton}"
                                        HorizontalAlignment="Center" Padding="12,8" Width="80">
                                    <Interaction.Behaviors>
                                        <ButtonClickEventTriggerBehavior>
                                            <LaunchUriOrFileAction Path="{Binding Url}" />
                                        </ButtonClickEventTriggerBehavior>
                                    </Interaction.Behaviors>
                                    <StackPanel Spacing="2" HorizontalAlignment="Center">
                                        <avalonia:MaterialIcon Kind="{Binding IconKind}"
                                                               Height="24" Width="24"
                                                               Foreground="{Binding IconColor}"
                                                               HorizontalAlignment="Center" />
                                        <TextBlock Foreground="{DynamicResource MaterialDesignBody}"
                                                   Text="{I18N {Binding Label}}"
                                                   HorizontalAlignment="Center"
                                                   FontSize="11" TextAlignment="Center" />
                                    </StackPanel>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.DataTemplates>
                    </ItemsControl>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>