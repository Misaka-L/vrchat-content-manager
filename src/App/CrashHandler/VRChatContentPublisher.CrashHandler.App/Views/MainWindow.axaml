<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:VRChatContentPublisher.CrashHandler.App.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="450"
        x:Class="VRChatContentPublisher.CrashHandler.App.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Width="900" Height="450" WindowStartupLocation="CenterScreen"
        Icon="/Assets/AppIcon.ico"
        Title="VRChat Content Publisher - Crash Handler">

    <Design.DataContext>
        <vm:MainWindowViewModel />
    </Design.DataContext>

    <ContentControl Content="{Binding CurrentView}" />

</Window>